# PostgreSQL
POSTGRES_USER=quran
POSTGRES_PASSWORD=quran
POSTGRES_DB=quran_tracker
DATABASE_URL=postgresql://quran:quran@db:5432/quran_tracker

# Server
PORT=3000
SITE_PORT=80
NODE_ENV=development
TZ=Asia/Bishkek

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed admin (used in migration 002)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Cookies & CORS
COOKIE_SECURE=false
CORS_ORIGIN=http://quran-tracker.local

# Telegram Login
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
